---
import '../styles/global.css'
import { HeroSection } from '../components/HeroSection'
import { PainSection } from '../components/PainSection'
import { ProcessSection } from '../components/ProcessSection'
import { ArsenalSection } from '../components/ArsenalSection'
import { CTASection } from '../components/CTASection'
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>B.E.R.G. - Bavaria Extraction & Recovery Group</title>
    <meta name="description" content="Wir holen dich raus. 24/7. Diskret. Professionell. Überall in Bayern. Spezialisiert auf die Extraktion von Personen, die unfreiwillig in Bayern festsitzen." />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;700;900&family=Barlow:wght@400;600&display=swap" rel="stylesheet" />

    <!-- OG -->
    <meta property="og:title" content="B.E.R.G. - Bavaria Extraction & Recovery Group" />
    <meta property="og:description" content="Wir holen dich raus. 24/7. Diskret. Professionell." />
    <meta property="og:type" content="website" />
  </head>

  <body>
    <!-- Nav -->
    <nav
      class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4"
      style="background: rgba(6,6,8,0.8); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.04);"
    >
      <div class="flex items-center gap-3">
        <img src="/logo.svg" alt="B.E.R.G. Logo" class="w-10 h-10" />
        <span class="font-black text-sm tracking-widest text-white uppercase">B.E.R.G.</span>
        <span class="hidden md:inline text-xs tracking-wider" style="color: var(--muted);">Bavaria Extraction & Recovery Group</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="#prozess" class="hidden sm:inline text-xs tracking-widest uppercase transition-colors hover:text-white" style="color: var(--muted);">Prozess</a>
        <a href="#arsenal" class="hidden sm:inline text-xs tracking-widest uppercase transition-colors hover:text-white" style="color: var(--muted);">Arsenal</a>
        <a
          href="tel:0800-RAUSHIER"
          class="px-5 py-2 rounded-full font-black text-xs tracking-widest uppercase text-black"
          style="background: var(--primary);"
        >
          0800-RAUS-HIER
        </a>
      </div>
    </nav>

    <!-- Sections -->
    <main>
      <HeroSection client:load />
      <PainSection client:visible />
      <ProcessSection client:visible />
      <ArsenalSection client:visible />
      <CTASection client:visible />
    </main>

    <!-- Footer -->
    <footer
      class="py-12 px-6 text-center"
      style="background: #040404; border-top: 1px solid rgba(255,255,255,0.04);"
    >
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center justify-center gap-3 mb-4">
          <img src="/logo.svg" alt="B.E.R.G. Logo" class="w-14 h-14" />
          <div>
            <p class="font-black text-sm tracking-widest text-white">B.E.R.G.</p>
            <p class="text-xs tracking-wider" style="color: var(--muted);">BAVARIA EXTRACTION & RECOVERY GROUP</p>
          </div>
        </div>
        <p class="text-xs mb-2" style="color: var(--muted);">
          Freiwillig da. Unfreiwillig drin. Wir holen dich raus.
        </p>
        <p class="text-[10px] mb-6 italic" style="color: rgba(255,255,255,0.12);">
          Einsatzgebiet: ganz Bayern inkl. Franken, Schwaben, Oberpfalz und dem Rest, den keiner kennt.
        </p>
        <div class="flex flex-wrap gap-6 justify-center text-xs tracking-wider" style="color: var(--muted);">
          <span>Datenschutz</span>
          <span>Impressum</span>
          <span>AGB</span>
          <span style="color: var(--primary);">0800-RAUS-HIER</span>
        </div>
        <p class="mt-8 text-xs" style="color: rgba(255,255,255,0.15);">
          &copy; 2026 B.E.R.G. GmbH - Satirische Website. Bayern ist natürlich wunderschön. Söder bestimmt auch.
        </p>
      </div>
    </footer>
  </body>
</html>
