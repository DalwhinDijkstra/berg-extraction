---
import '../styles/global.css'
import { HeroSection } from '../components/HeroSection'
import { PainSection } from '../components/PainSection'
import { ProcessSection } from '../components/ProcessSection'
import { ArsenalSection } from '../components/ArsenalSection'
import { CTASection } from '../components/CTASection'
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>B.E.R.G. - Bavaria Extraction & Recovery Group</title>
    <meta name="description" content="Wir holen dich raus. 24/7. Diskret. Professionell. Überall in Bayern. Spezialisiert auf die Extraktion von Personen, die unfreiwillig in Bayern festsitzen." />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;700;900&family=Barlow:wght@400;600&display=swap" rel="stylesheet" />

    <!-- OG -->
    <meta property="og:title" content="B.E.R.G. - Bavaria Extraction & Recovery Group" />
    <meta property="og:description" content="Wir holen dich raus. 24/7. Diskret. Professionell." />
    <meta property="og:type" content="website" />
  </head>

  <body>
    <!-- Nav -->
    <nav
      class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4"
      style="background: rgba(6,6,8,0.8); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.04);"
    >
      <div class="flex items-center gap-3">
        <img src="/logo.png" alt="B.E.R.G. Logo" class="w-10 h-10 rounded" />
        <span class="font-black text-base tracking-widest text-white uppercase">B.E.R.G.</span>
        <span class="hidden md:inline text-sm tracking-wider" style="color: #bbb;">Bavaria Extraction & Recovery Group</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="#prozess" class="hidden sm:inline text-sm tracking-widest uppercase transition-colors hover:text-white" style="color: #bbb;">Prozess</a>
        <a href="#arsenal" class="hidden sm:inline text-sm tracking-widest uppercase transition-colors hover:text-white" style="color: #bbb;">Arsenal</a>
        <a
          href="tel:0800-RAUSHIER"
          class="px-5 py-2.5 rounded-full font-black text-sm tracking-widest uppercase text-black"
          style="background: var(--primary);"
        >
          0800-RAUS-HIER
        </a>
      </div>
    </nav>

    <!-- Sections -->
    <main>
      <HeroSection client:load />
      <PainSection client:visible />
      <ProcessSection client:visible />
      <ArsenalSection client:visible />
      <CTASection client:visible />
    </main>

    <!-- Footer -->
    <footer
      class="py-32 px-6 text-center"
      style="background: #040404; border-top: 1px solid rgba(255,255,255,0.04);"
    >
      <div style="max-width: 56rem; margin-inline: auto;">
        <div style="display: flex; align-items: center; justify-content: center; gap: 1rem; margin-bottom: 2.5rem;">
          <img src="/logo.png" alt="B.E.R.G. Logo" style="width: 4rem; height: 4rem; border-radius: 0.25rem;" />
          <div style="text-align: left;">
            <p class="font-black text-base tracking-widest text-white">B.E.R.G.</p>
            <p class="text-sm tracking-wider" style="color: #bbb;">BAVARIA EXTRACTION & RECOVERY GROUP</p>
          </div>
        </div>
        <p class="text-base mb-4" style="color: #bbb;">
          Freiwillig da. Unfreiwillig drin. Wir holen dich raus.
        </p>
        <p class="text-sm mb-10 italic" style="color: #999;">
          Einsatzgebiet: ganz Bayern inkl. Franken, Schwaben, Oberpfalz und dem Rest, den keiner kennt.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 2rem; justify-content: center; color: #bbb;" class="text-sm tracking-wider">
          <span>Datenschutz</span>
          <span>Impressum</span>
          <span>AGB</span>
          <span style="color: var(--primary);">0800-RAUS-HIER</span>
        </div>
        <p class="mt-12 text-sm" style="color: #888;">
          &copy; 2026 B.E.R.G. GmbH - Satirische Website. Bayern ist natuerlich wunderschoen. Soeder bestimmt auch.
        </p>
      </div>
    </footer>
  </body>
</html>
